	dictionary *
	Option* $mol_check
		checked? <=> option_checked*? false
		label <= option_label* /
			<= option_title* \
		enabled <= option_enabled* <= enabled true
		hint <= option_hint* \
		minimal_height 24
	options *
	keys /string
	sub <= items /$mol_check

$mol_switch $mol_check_list
	value? \

$bog_klik_app $mol_page
	title @ \klik
	pages *
		play <= Play $bog_klik_play
		board <= Board $bog_klik_board
		bench <= Bench $bog_klik_bench
	nav_options *
		play \Клик
		board \Лидерборд
		bench \Нагрузка
