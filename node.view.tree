$bog_klik_play $mol_page
	title @ \Клик
	store $bog_klik_store
	auto_click? false
	tick_ms? 1000
	per_tick? 1
	body /
		<= Start_block $mol_view sub <= start_block /
			<= Intro $mol_text text @ \
				\# klik
				\
				\Нет активной сессии. Создай новую или открой по ссылке `?land=...`.
			<= Create $mol_button_major
				click? <=> create_click? null
				sub / \Создать сессию
		<= Game_block $mol_view sub <= game_block /
			<= Params $mol_list rows /
				<= Name_field $mol_string
					hint @ \Имя
					value? <=> name? \
				<= Score_row $mol_paragraph
					title <= score_title \Счёт: 0
				<= Share_row $mol_paragraph
					title <= share_title \Ссылка:
				<= Share_link $mol_string
					enabled false
					value <= session_link \
				<= Tick_row $mol_number
					hint @ \Мс на тик
					value? <=> tick_ms? 1000
				<= Per_tick_row $mol_number
					hint @ \Кликов за тик
					value? <=> per_tick? 1
			<= Click $mol_button_major
				click? <=> click? null
				sub / \+1
			<= Auto $mol_check
				checked? <=> auto_click? false
				label / \Автокликер

$bog_klik_board $mol_page
	title @ \Лидерборд
	store $bog_klik_store
	body /
		<= Total $mol_paragraph
			title <= total_title \Игроков: 0
		<= List $mol_list
			rows <= rows /
	Row* $mol_view
		sub /
			<= Rank* $mol_view sub / <= rank* \0.
			<= Name* $mol_view sub / <= player_name* \—
			<= Score* $mol_view sub / <= player_score* \0

$bog_klik_bench $mol_page
	title @ \Нагрузка
	store $bog_klik_store
	bots_count? 10
	bot_tick_ms? 1000
	bot_per_tick? 1
	running? false
	body /
		<= Params $mol_list rows /
			<= Count_field $mol_number
				hint @ \Количество ботов
				value? <=> bots_count? 10
			<= Tick_field $mol_number
				hint @ \Мс на тик
				value? <=> bot_tick_ms? 1000
			<= Per_field $mol_number
				hint @ \Кликов за тик
				value? <=> bot_per_tick? 1
		<= Toggle $mol_check
			checked? <=> running? false
			label / \Запустить
		<= Metrics $mol_list rows /
			<= Ops $mol_paragraph title <= ops_title \Ops/s: 0
			<= Writes $mol_paragraph title <= writes_title \Всего записей: 0
			<= Latency $mol_paragraph title <= latency_title \Лаг аплая, мс: 0

